# Supabase — get these from https://supabase.com/dashboard/project/<project-id>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Claude API — get from https://console.anthropic.com/
# Used only for batched transaction categorization (once per import session)
VITE_CLAUDE_API_KEY=sk-ant-...

# ExchangeRate-API — get from https://www.exchangerate-api.com/ (free tier: 1500 req/month)
VITE_EXCHANGE_RATE_API_KEY=your-api-key
